# Copy this file to .env and pick one API base.
# Expo will expose EXPO_PUBLIC_* variables to the app.

# Local backend on same machine (web / simulator)
# EXPO_PUBLIC_API_BASE=http://127.0.0.1:8000

# Local backend on LAN (physical phone)
EXPO_PUBLIC_API_BASE=http://192.168.10.50:8000

# Demo/staging backend
# EXPO_PUBLIC_API_BASE=https://demo.example.com
