# Copy this file to .env and fill in your values.
# The .env file is gitignored and never committed.

# OpenAI API key — get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Optional: override the default model (default: gpt-4o-mini)
# LLM_MODEL=gpt-4o

# OpenAI-compatible fallback endpoint (optional)
# Example: Groq
# FALLBACK_LLM_API_KEY=gsk_...
# FALLBACK_LLM_BASE_URL=https://api.groq.com/openai/v1
# FALLBACK_LLM_MODEL=llama-3.1-8b-instant

# Ollama — paikallinen LLM, viimeisin fallback (ei API-avainta tarvita)
# Asenna: https://ollama.com
# Käynnistä: ollama serve
# Lataa malli: ollama pull llama3.2
#
# Oletusasetukset (ei tarvitse muuttaa jos käytät oletusporttia):
# OLLAMA_ENABLED=true
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=llama3.2
# PROVIDER_TIMEOUT_OLLAMA_SECONDS=30
#
# Poista käytöstä:
# OLLAMA_ENABLED=false
