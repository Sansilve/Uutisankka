# Copy this file to .env and fill in your values.
# The .env file is gitignored and never committed.

# OpenAI API key — get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Optional: override the default model (default: gpt-4o-mini)
# LLM_MODEL=gpt-4o

# Optional: CORS settings for frontend clients
# Comma-separated explicit origins (recommended)
# CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://192.168.10.50:8081

# Optional origin regex (default allows localhost + 192.168.x.x with any port)
# CORS_ALLOW_ORIGIN_REGEX=https?://(localhost|127\.0\.0\.1|192\.168\.\d+\.\d+)(:\d+)?$
