# Copy this file to .env and fill in your values.
# The .env file is gitignored and never committed.

# OpenAI API key — get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Optional: override the default model (default: gpt-4o-mini)
# LLM_MODEL=gpt-4o

# OpenAI-compatible fallback endpoint (optional)
# Example: Groq, local proxy, or Ollama OpenAI-compatible API
# FALLBACK_LLM_API_KEY=your-key
# FALLBACK_LLM_BASE_URL=https://api.groq.com/openai/v1
# FALLBACK_LLM_MODEL=llama-3.1-8b-instant

# Ollama (optional - local LLM, last resort fallback)
# Start with:
#   ollama serve
#   ollama pull mistral
# FALLBACK_LLM_API_KEY=ollama
# FALLBACK_LLM_BASE_URL=http://localhost:11434/v1
# FALLBACK_LLM_MODEL=mistral
